#!/usr/bin/env sh
# Pre-commit hook: runs lint-staged then the full test suite.
# This ensures no broken code or failing tests ever reach the repo.
#
# SECURITY: Linting catches dangerous patterns (eval, dangerouslySetInnerHTML)
# before they are committed. Tests validate security-critical logic
# (rate limiter, input validation) on every commit.

# Run lint-staged (lint + type-check only staged files)
npx lint-staged

# Run full test suite — fail the commit if any test fails
npm test
