# ── Stage 1: Install deps ───────────────────────────────────────────────────
FROM node:20-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci

# ── Stage 2: Production runner ───────────────────────────────────────────────
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

RUN addgroup --system --gid 1001 nodejs \
 && adduser  --system --uid 1001 agentuser

COPY --from=deps /app/node_modules ./node_modules
COPY --chown=agentuser:nodejs src    ./src
COPY --chown=agentuser:nodejs prisma ./prisma
COPY tsconfig.json  ./
COPY package.json   ./

# Generate Prisma client for Linux
RUN npx prisma generate

USER agentuser

# Cloud Run requires a port even for non-HTTP workers
ENV PORT=8080
EXPOSE 8080

CMD ["npx", "tsx", "src/agent/telephony-agent.ts", "start"]
